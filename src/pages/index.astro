---
import Layout from "../layouts/Layout.astro";
import Info from "../components/Info.astro";
import Links from "../components/Links.astro";
---

<Layout title={import.meta.env.NAME}>
  <main class="page">
    <section class="panel" aria-label="Profile">
      <Info name={import.meta.env.NAME} heading={import.meta.env.HEADING} />
      <Links
        linkedin={import.meta.env.LINKEDIN}
        github={import.meta.env.GITHUB}
        url={import.meta.env.URL}
        mysite={import.meta.env.MYSITE}
        sitekey={import.meta.env.SITEKEY}
      />
    </section>
  </main>
</Layout>

<style>
  .page {
    min-height: 100vh;
    padding: clamp(1.5rem, 6vw, 5.5rem);
    display: grid;
    align-items: center;
  }

  .panel {
    width: min(1020px, 100%);
    margin: 0 auto;
    padding: clamp(1.4rem, 4.5vw, 4rem);
    border: 1px solid var(--line);
    background: var(--surface);
    box-shadow:
      0 22px 44px rgb(21 27 38 / 6%),
      0 1px 0 rgb(255 255 255 / 70%) inset;
    animation: settle 420ms ease-out both;
  }

  @keyframes settle {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 640px) {
    .page {
      padding: 1rem;
      align-items: start;
    }

    .panel {
      margin-top: 0.75rem;
      padding: 1.2rem;
    }
  }
</style>
