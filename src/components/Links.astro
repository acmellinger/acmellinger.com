---
import { Icon } from "astro-icon/components";
interface Props {
  linkedin: string;
  github: string;
  url: string;
  mysite: string;
  sitekey: string;
}

const { linkedin, github, url, mysite, sitekey } = Astro.props;
const localBypassEnabled =
  import.meta.env.DEV && import.meta.env.PUBLIC_TURNSTILE_LOCAL_BYPASS === "true";
const localTestEmail = import.meta.env.PUBLIC_TEST_EMAIL ?? "local@example.com";
---

<div class="links-wrap">
  <nav class="links" role="group" aria-label="Primary links">
    <button title="Reveal Email" aria-label="Reveal Email" id="emailBtn" class="action">
      <Icon name="mdi:email-fast-outline" class="icon" />
      <span>Email</span>
    </button>
    <a
      class="action"
      title="LinkedIn"
      aria-label="My LinkedIn"
      target="_blank"
      rel="noopener noreferrer"
      href={linkedin}
    >
      <Icon name="mdi:linkedin" class="icon" />
      <span>LinkedIn</span>
    </a>
    <a
      class="action"
      title="GitHub"
      aria-label="My Github"
      target="_blank"
      rel="noopener noreferrer"
      href={github}
    >
      <Icon name="mdi:github" class="icon" />
      <span>GitHub</span>
    </a>
  </nav>

  <div id="email-container" class="email-container" aria-live="polite">
    <a id="emailtext" class="emailtext" tabindex="-1"></a>
    <span id="statustext" class="statustext"></span>
  </div>
</div>

<div
  class="cf-turnstile turnstile"
  id="turnstile-widget"
  data-sitekey={sitekey}
  data-callback="onTurnstileSuccess"
  data-error-callback="onTurnstileError"
  data-expired-callback="onTurnstileExpired"
  data-execution="execute"
>
</div>

<script
  is:inline
  define:vars={{ url, mysite, localBypassEnabled, localTestEmail }}
>
  function setStatus(message) {
    const statusText = document.getElementById("statustext");
    if (statusText) {
      statusText.innerText = message;
    }
  }

  function setEmail(email) {
    const anchorElement = document.getElementById("emailtext");
    if (anchorElement) {
      anchorElement.setAttribute(
        "href",
        "mailto:" + email + "?subject=Website Contact",
      );
      anchorElement.innerText = email;
      anchorElement.removeAttribute("tabindex");
    }
  }

  function setVerifyingState(loading) {
    const button = document.getElementById("emailBtn");
    if (button) {
      button.toggleAttribute("disabled", loading);
      button.setAttribute("aria-busy", loading ? "true" : "false");
    }
  }

  window.onTurnstileError = function () {
    setVerifyingState(false);
    setStatus("Verification unavailable");
  };

  window.onTurnstileExpired = function () {
    setVerifyingState(false);
    setStatus("Verification expired");
  };

  window.onTurnstileSuccess = async function (token) {
    let timeout;
    try {
      const controller = new AbortController();
      timeout = window.setTimeout(() => controller.abort(), 10000);
      const response = await fetch(url, {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({ Token: token, Site: mysite }),
        signal: controller.signal,
      });

      if (response.status !== 200) {
        throw new Error("Validation failed");
      }

      const rjson = await response.json();
      const email = rjson["email"];
      const isValidEmail =
        typeof email === "string" &&
        email.length > 3 &&
        email.includes("@") &&
        email.includes(".");

      if (!isValidEmail) {
        throw new Error("Invalid response");
      }

      setEmail(email);
      setStatus("");
    } catch (e) {
      setStatus("Verification failed");
      if (window.turnstile) {
        window.turnstile.reset("#turnstile-widget");
      }
    } finally {
      if (timeout) {
        window.clearTimeout(timeout);
      }
      setVerifyingState(false);
    }
  };
</script>

<script
  is:inline
  define:vars={{ localBypassEnabled, localTestEmail, sitekey, url, mysite }}
>
  function onEmailClick() {
    const button = document.getElementById("emailBtn");
    if (button?.getAttribute("aria-busy") === "true") {
      return;
    }

    if (localBypassEnabled) {
      const anchorElement = document.getElementById("emailtext");
      if (anchorElement) {
        anchorElement.setAttribute(
          "href",
          "mailto:" + localTestEmail + "?subject=Website Contact",
        );
        anchorElement.innerText = localTestEmail;
      }
      const statusText = document.getElementById("statustext");
      if (statusText) {
        statusText.innerText = "Local test mode";
      }
      return;
    }

    const statusText = document.getElementById("statustext");
    if (statusText) {
      statusText.innerText = "Verifying";
    }

    const emailElement = document.getElementById("emailtext");
    if (emailElement) {
      emailElement.innerText = "";
      emailElement.removeAttribute("href");
    }

    if (!sitekey || !url || !mysite) {
      if (statusText) {
        statusText.innerText = "Missing Turnstile configuration";
      }
      return;
    }

    if (button) {
      button.setAttribute("aria-busy", "true");
      button.toggleAttribute("disabled", true);
    }

    if (window.turnstile && window.turnstile.execute) {
      window.turnstile.execute("#turnstile-widget");
    } else if (statusText) {
      if (button) {
        button.setAttribute("aria-busy", "false");
        button.removeAttribute("disabled");
      }
      statusText.innerText = "Verification unavailable";
    }
  }

  const button = document.getElementById("emailBtn");
  if (button) {
    button.addEventListener("click", onEmailClick);
  }
</script>

<style>
  .links-wrap {
    display: grid;
    gap: 0.9rem;
  }

  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }

  .action {
    appearance: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    border: 1px solid var(--line-strong);
    background: transparent;
    color: var(--text);
    padding: 0.66rem 1.02rem;
    text-decoration: none;
    text-transform: uppercase;
    font-family: "Montserrat", "Avenir Next", "Segoe UI", sans-serif;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    line-height: 1;
    cursor: pointer;
    transition:
      background-color 160ms ease,
      border-color 160ms ease,
      color 160ms ease;
  }

  .action:disabled {
    opacity: 0.6;
    cursor: progress;
  }

  .action:hover {
    background: #f4f1eb;
    border-color: #b9ad99;
    color: var(--text);
    outline: none;
  }

  .action:focus-visible {
    background: #f4f1eb;
    border-color: #b9ad99;
    color: var(--text);
    outline: 2px solid var(--text);
    outline-offset: 2px;
  }

  :global(.icon) {
    color: currentColor;
    width: 0.95rem;
    height: 0.95rem;
  }

  .email-container {
    min-height: 1.6rem;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .emailtext {
    color: var(--text);
    font-family: "Montserrat", "Avenir Next", "Segoe UI", sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-underline-offset: 0.14em;
    overflow-wrap: anywhere;
  }

  .statustext {
    color: var(--muted);
    font-family: "Montserrat", "Avenir Next", "Segoe UI", sans-serif;
    font-size: 0.74rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .statustext:empty {
    display: none;
  }

  .turnstile {
    position: absolute;
    width: 0;
    height: 0;
    opacity: 0;
    overflow: hidden;
    pointer-events: none;
  }

  @media (max-width: 640px) {
    .action {
      width: 100%;
      justify-content: center;
    }
  }
</style>
